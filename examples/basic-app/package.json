{
  "name": "basic-app",
  "private": true,
  "type": "module",
  "scripts": {
    "smart-images:sync-manifest": "node ../../packages/ng-smart-images/dist/cli.js sync-manifest",
    "smart-images:generate": "node ../../packages/ng-smart-images/dist/cli.js generate-hashed",
    "smart-images:update-bundle": "node ../../packages/ng-smart-images/dist/cli.js update-bundle --dist dist/basic-app/browser",
    "build": "npm run smart-images:generate && ng build && npm run smart-images:update-bundle",
    "start": "npm run smart-images:generate && ng serve"
  },
  "dependencies": {
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@yadimon/ng-smart-images": "*",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "typescript": "~5.9.2"
  }
}
